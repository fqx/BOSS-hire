# OpenAI cloud configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1  # optional, override for proxy or local servers
LLM_MODEL=gpt-4o-mini

# LM Studio local configuration (uncomment to use)
# OPENAI_API_KEY=lm-studio        # LM Studio does not validate the key, any string works
# OPENAI_BASE_URL=http://localhost:1234/v1
# LLM_MODEL=qwen2.5-vl-7b-instruct  # must be a vision-capable model

LOG_LEVEL=INFO
